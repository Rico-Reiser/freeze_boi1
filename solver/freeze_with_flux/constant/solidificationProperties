FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      solidificationProperties;
}

Tsolid      273.00;                       // [K]
Tliquid     273.65;                       // [K]
latentHeat  3.34e5;                       // [J/kg]

water
{
    rho               1000;               // [kg/m^3]
    cp                4180;               // [J/(kg*K)]
    lambda            0.6;                // [W/(m*K)]
    lambdaSolid       2.2;                // [W/(m*K)]
    lambdaLiquid      0.6;                // [W/(m*K)]
}

contactFluid
{
    rho           1200;                   // [kg/m^3]
    cp            2500;                   // [J/(kg*K)]
    lambda        0.5;                    // [W/(m*K)]
}

air
{
    rho          1.2;                     // [kg/m^3]
    cp           1005;                    // [J/(kg*K)]
    lambda       0.03;                    // [W/(m*K)]
}
heatTransfer
{
    // water - contactFluid
    K_wc    1e7;                          // [W/(m^3*K)]

    // water - air
    K_wa    5e5;                          // [W/(m^3*K)]

    // contactFluid - air
    K_ca    0;                            // [W/(m^3*K)]
}

