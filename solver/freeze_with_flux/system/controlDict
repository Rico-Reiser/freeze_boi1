FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     gallardoFoam;

startFrom       latestTime;
startTime       0;

stopAt          endTime;
endTime         20;

deltaT          1e-5;

// ============================
// WRITE CONTROL  ✅ FIX
// ============================
writeControl    runTime;
writeInterval   0.1;

purgeWrite      0;

writeFormat     ascii;
writePrecision  8;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable yes;

// ============================
// ZEITSCHRITT-KONTROLLE
// ============================
adjustTimeStep  yes;

maxCo           0.2;
maxAlphaCo      0.05;
maxDeltaT       1e-3;

// ============================
// FUNKTIONEN (DEBUG)
// ============================
